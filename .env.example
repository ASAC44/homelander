PORT=3000
HOMELANDER_MOCK_MODE=false
HOMELANDER_MOCK_MIN_DURATION_MS=60000
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# OpenAI-compatible API — works with OpenAI, Ollama, vLLM, Together, Groq, etc.
# Set BASE_URL to any OpenAI-compatible endpoint (e.g. http://localhost:11434/v1 for Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_REASONING_EFFORT=low
# OpenAI-compatible provider throttling. Defaults: custom BASE_URL => 1, official OpenAI => 3.
OPENAI_MAX_CONCURRENCY=
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_BASE_MS=750
OPENAI_RETRY_MAX_MS=8000
OPENAI_RATE_LIMIT_COOLDOWN_MS=60000

BRIGHTDATA_API_TOKEN=
BRIGHTDATA_PRO_MODE=false

# Report & evidence storage
REPORT_STORAGE_DIR=./data/reports
EVIDENCE_STORAGE_DIR=./data/evidence
EVIDENCE_TTL_HOURS=72

# LaTeX compiler: tectonic (default) or latexmk
LATEX_COMPILER=tectonic
# Compile timeout in milliseconds (default 120000)
LATEX_COMPILE_TIMEOUT=120000
# Set to false to delete intermediate .tex files after compilation
REPORT_KEEP_TEX=true

# Public base URL for serving evidence files (optional)
# When set, enables GET /evidence/:id and clickable evidence links in Slack
PUBLIC_BASE_URL=
